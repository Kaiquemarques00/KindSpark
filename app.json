{
  "expo": {
    "name": "KindSpark",
    "slug": "kindspark",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-kindspark.png",
    "scheme": "kindspark",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kindspark.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-kindspark.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5B7C99"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c90a2333-6855-4b6c-8f1d-f641258a84e4"
      }
    },
    "owner": "kaiquemarques00"
  }
}
